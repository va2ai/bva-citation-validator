{
  "name": "bva-citation-validator",
  "version": "1.0.0",
  "description": "Post-generation citation validator for BVA legal intelligence platform",
  "type": "module",
  "main": "validator.js",
  "scripts": {
    "start": "node server.js",
    "cli": "node validator.js",
    "validate": "node validator.js",
